# ── Database ──────────────────────────────────────────────────────────────────
# SQLite local: file:./prisma/dev.db
# Turso (produção): libsql://your-db.turso.io
DATABASE_URL="file:./prisma/dev.db"
TURSO_AUTH_TOKEN=""

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"
# ID do cliente Google (Google Credentials Console)
GOOGLE_CLIENT_ID=""


# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADO_PAGO_ACCESS_TOKEN=""
# Chave secreta do webhook — configure no painel do MP → Webhooks → Chave secreta
MERCADO_PAGO_WEBHOOK_SECRET=""

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
# Crie uma API Key em: https://resend.com/api-keys
RESEND_API_KEY=""
# Deve ser um endereço do domínio verificado no Resend
EMAIL_FROM="suporte@rokomed.com.br"

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL do frontend (sem barra final)
FRONTEND_URL="http://localhost:5173"
PORT=3000
NODE_ENV="development"

# ── Cron ──────────────────────────────────────────────────────────────────────
# Chave secreta para proteger o endpoint POST /subscriptions/check-expiry
# Configure no seu serviço de cron (ex: cron-job.org → Header: x-cron-secret: <valor>)
CRON_SECRET="troque-por-string-aleatoria"
