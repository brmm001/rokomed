// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enums — Role, Plan e Difficulty são String com validação na app layer
// Role values: ALUNO | PROFESSOR | ADMIN | SUPERADMIN
// Plan values: FREE | PRO | GRUPO
// Difficulty values: FACIL | MEDIO | DIFICIL

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  picture         String?
  passwordHash    String?
  googleId        String?   @unique
  role            String    @default("ALUNO")
  plan            String    @default("FREE")
  xp              Int       @default(0)
  streak          Int       @default(0)
  lastStudyDate   DateTime?
  examDate        DateTime?              // data-alvo da prova
  cutoffScore     Float?                 // nota de corte definida pelo aluno (0-100)
  targetInstitutionId String?            // instituição pretendida
  isBanned        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  answers         UserAnswer[]
  bookmarks       UserBookmark[]
  notes           UserNote[]
  highlights      UserHighlight[]
  subscriptions   Subscription[]
  payments        Payment[]
  flashcards      Flashcard[]
  groupMemberships GroupMember[]
  adminLogs       AdminLog[]
  trialIps        TrialIp[]
  mockExams       MockExam[]
  thetas          UserTheta[]
  adaptiveSessions AdaptiveSession[]
  analytics       UserAnalytics[]
  alerts          UserAlert[]

  @@map("users")
}

model Specialty {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  description  String?
  parentId     String?
  isGrandeArea Boolean    @default(false)
  parent       Specialty? @relation("SpecialtyHierarchy", fields: [parentId], references: [id])
  children     Specialty[] @relation("SpecialtyHierarchy")
  questions    Question[]

  @@map("specialties")
}

model Institution {
  id        String     @id @default(cuid())
  name      String     @unique
  acronym   String     @unique
  city      String?
  state     String?
  questions Question[]

  @@map("institutions")
}

model Question {
  id            String      @id @default(cuid())
  code          String      @unique @default(cuid())
  year          Int?
  statement     String      // HTML rico (TipTap)
  options       String      // JSON: [{ letter: 'A', text: '...' }, ...]
  correctOption String?     // 'A' | 'B' | 'C' | 'D' | 'E' — preenchido ao importar gabarito
  explanation   String?     // HTML comentário
  reasoningLine String?     // Linha de raciocínio (vem do 2º arquivo)
  difficulty    String      @default("MEDIO")
  isPublished   Boolean     @default(false)
  flagCount     Int         @default(0)
  specialtyId   String?
  institutionId String?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  specialty     Specialty?    @relation(fields: [specialtyId], references: [id])
  institution   Institution?  @relation(fields: [institutionId], references: [id])
  images        QuestionImage[]
  answers       UserAnswer[]
  bookmarks     UserBookmark[]
  notes         UserNote[]
  highlights    UserHighlight[]
  flashcards    Flashcard[]
  mockExamQuestions MockExamQuestion[]
  irt           QuestionIRT?

  @@map("questions")
}

// ── Simulado Personalizado ─────────────────────────────────────────────────

model MockExam {
  id             String   @id @default(cuid())
  userId         String
  title          String
  totalQuestions Int
  timeLimitMin   Int?     // minutos (null = sem limite)
  config         String   // JSON: { difficulties[], institutionIds[], specialtyIds[], years[] }
  status         String   @default("PENDING") // PENDING | IN_PROGRESS | FINISHED
  currentIndex   Int      @default(0)
  correctCount   Int      @default(0)
  score          Int?     // % de acerto (0-100) ao finalizar
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions MockExamQuestion[]

  @@map("mock_exams")
}

model MockExamQuestion {
  id          String    @id @default(cuid())
  mockExamId  String
  questionId  String
  order       Int
  selectedOpt String?
  isCorrect   Boolean?
  answeredAt  DateTime?

  mockExam MockExam @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([mockExamId, order])
  @@map("mock_exam_questions")
}

model QuestionImage {
  id         String   @id @default(cuid())
  questionId String
  url        String
  caption    String?
  order      Int      @default(0)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_images")
}

model UserAnswer {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  selectedOpt  String
  isCorrect    Boolean
  timeSpentSec Int?
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("user_answers")
}

model UserBookmark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_bookmarks")
}

model UserNote {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  content    String
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_notes")
}

model UserHighlight {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  rangeJson  String   // JSON: { start, end, text }
  color      String   @default("#fde68a")
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("user_highlights")
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  plan        String   // FREE | PRO | GRUPO
  status      String   // active | trial | cancelled | expired
  trialEndsAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model TrialIp {
  id        String   @id @default(cuid())
  ip        String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trial_ips")
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String    // percent | fixed
  value         Float
  usesRemaining Int       @default(1)
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@map("coupons")
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  mercadoPagoId     String?  @unique
  plan              String   // FREE | PRO | GRUPO
  amount            Float
  currency          String   @default("BRL")
  status            String   // pending | approved | rejected | refunded
  paymentMethod     String?  // pix | credit_card
  couponCode        String?
  webhookPayload    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model StudyGroup {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique @default(cuid())
  ownerId     String
  maxMembers  Int      @default(30)
  createdAt   DateTime @default(now())

  members GroupMember[]

  @@map("study_groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("student") // student | teacher
  joinedAt  DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Flashcard {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  front      String
  back       String
  easeFactor Float    @default(2.5)
  interval   Int      @default(1)
  dueDate    DateTime @default(now())
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

// ── IRT / CAT / Adaptive Intelligence ──────────────────────────────────────

model QuestionIRT {
  id           String   @id @default(cuid())
  questionId   String   @unique
  a            Float    @default(1.0)
  b            Float    @default(0.0)
  c            Float    @default(0.2)
  calibrated   Boolean  @default(false)
  nResponses   Int      @default(0)
  lastCalibAt  DateTime?
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@map("question_irt")
}

model UserTheta {
  id           String   @id @default(cuid())
  userId       String
  specialtyId  String?
  theta        Float    @default(0.0)
  se           Float    @default(1.0)
  nAnswers     Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, specialtyId])
  @@map("user_thetas")
}

model AdaptiveSession {
  id           String   @id @default(cuid())
  userId       String
  specialtyId  String?
  thetaStart   Float
  thetaEnd     Float?
  seStart      Float
  seEnd        Float?
  totalItems   Int      @default(0)
  correctCount Int      @default(0)
  status       String   @default("ACTIVE")
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        AdaptiveSessionItem[]
  @@map("adaptive_sessions")
}

model AdaptiveSessionItem {
  id           String    @id @default(cuid())
  sessionId    String
  questionId   String
  order        Int
  thetaBefore  Float
  thetaAfter   Float?
  seBefore     Float
  seAfter      Float?
  fisherInfo   Float
  selectedOpt  String?
  isCorrect    Boolean?
  timeSpentSec Int?
  answeredAt   DateTime?
  session      AdaptiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  @@map("adaptive_session_items")
}

model UserAnalytics {
  id              String   @id @default(cuid())
  userId          String
  specialtyId     String?
  period          String
  periodDate      DateTime
  thetaMean       Float
  thetaSe         Float
  accuracy        Float
  nAnswers        Int
  cusumStat       Float    @default(0)
  cusumAlert      Boolean  @default(false)
  brierScore      Float?
  pApproval       Float?
  learningRate    Float?
  chiSquarePVal   Float?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_analytics")
}

model UserAlert {
  id          String   @id @default(cuid())
  userId      String
  type        String
  severity    String
  title       String
  message     String
  data        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_alerts")
}
